{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Penguin Drive",
	"version": "1.0.5",
	"identifier": "me.rodrigoleon.penguindrive",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Penguin Drive",
				"width": 1200,
				"height": 800,
				"minWidth": 1000,
				"minHeight": 700,
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": "default-src 'self'; connect-src 'self' http://localhost:14200; media-src 'self' http://localhost:14200; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'",
			"capabilities": ["default"]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
